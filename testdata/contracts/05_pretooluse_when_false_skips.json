{
  "name": "PreToolUse allow when condition is false (contains no match)",
  "event_type": "PreToolUse",
  "config": {
    "guards": [
      {
        "match": "Bash",
        "action": "block",
        "reason": "Force push is forbidden",
        "when": "tool_input.command contains \"force\""
      }
    ]
  },
  "stdin": {
    "session_id": "contract-session-005",
    "tool_name": "Bash",
    "tool_input": {
      "command": "git pull origin main"
    }
  },
  "expected_stdout": null,
  "expected_exit_code": 0
}
