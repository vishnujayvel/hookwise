{
  "name": "PreToolUse confirm with equals operator",
  "event_type": "PreToolUse",
  "config": {
    "guards": [
      {
        "match": "Bash",
        "action": "confirm",
        "reason": "Staging deploys need confirmation",
        "when": "tool_input.env equals \"staging\""
      }
    ]
  },
  "stdin": {
    "session_id": "contract-session-010",
    "tool_name": "Bash",
    "tool_input": {
      "env": "staging",
      "command": "deploy.sh"
    }
  },
  "expected_stdout": "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Staging deploys need confirmation\"}}",
  "expected_exit_code": 0
}
