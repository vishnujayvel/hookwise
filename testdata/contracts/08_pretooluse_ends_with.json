{
  "name": "PreToolUse block with ends_with operator",
  "event_type": "PreToolUse",
  "config": {
    "guards": [
      {
        "match": "Write",
        "action": "block",
        "reason": "Cannot write .env files",
        "when": "tool_input.file_path ends_with \".env\""
      }
    ]
  },
  "stdin": {
    "session_id": "contract-session-008",
    "tool_name": "Write",
    "tool_input": {
      "file_path": "/home/user/project/.env"
    }
  },
  "expected_stdout": "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Cannot write .env files\"}}",
  "expected_exit_code": 0
}
